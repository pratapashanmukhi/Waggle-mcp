{
  "name": "waggle-memory",
  "displayName": "Waggle: Local Memory for AI Agents",
  "description": "Local graph memory for coding agents using MCP.",
  "version": "0.1.0",
  "publisher": "Abhigyan-Shekhar",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Abhigyan-Shekhar/Waggle-mcp",
  "bugs": {
    "url": "https://github.com/Abhigyan-Shekhar/Waggle-mcp/issues"
  },
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Abhigyan-Shekhar/Waggle-mcp"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Waggle will not download binaries or start servers until this workspace is trusted."
    }
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "MCP",
    "AI",
    "Copilot",
    "Agents",
    "Memory",
    "Knowledge Graph"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "contributes": {
    "commands": [
      {
        "command": "waggle.enableWorkspace",
        "title": "Waggle: Enable for this Workspace"
      },
      {
        "command": "waggle.install",
        "title": "Waggle: Install Waggle"
      },
      {
        "command": "waggle.doctor",
        "title": "Waggle: Run Doctor"
      },
      {
        "command": "waggle.openGraphStudio",
        "title": "Waggle: Open Graph Studio"
      },
      {
        "command": "waggle.showStatus",
        "title": "Waggle: Show Status"
      },
      {
        "command": "waggle.exportMemory",
        "title": "Waggle: Export Memory"
      },
      {
        "command": "waggle.openInstallDocs",
        "title": "Waggle: Open Install Docs"
      },
      {
        "command": "waggle.queryMemory",
        "title": "Waggle: Query Memory"
      },
      {
        "command": "waggle.observeConversation",
        "title": "Waggle: Observe Conversation"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "waggle",
          "title": "Waggle",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "waggle": [
        {
          "id": "waggle.graphStudio",
          "name": "Graph Studio",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Waggle",
      "properties": {
        "waggle.commandPath": {
          "type": "string",
          "default": "waggle-mcp",
          "description": "Command used when installMethod is pipx."
        },
        "waggle.dbPath": {
          "type": "string",
          "default": "~/.waggle/waggle.db",
          "description": "Default Waggle SQLite database path."
        },
        "waggle.tenantId": {
          "type": "string",
          "default": "${workspaceFolderBasename}",
          "description": "Tenant ID used for workspace memory."
        },
        "waggle.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start the local Waggle HTTP server when a workspace opens."
        },
        "waggle.installMethod": {
          "type": "string",
          "default": "binary",
          "enum": ["pipx", "binary"],
          "description": "Install method: bundled binary download or pipx."
        },
        "waggle.binaryReleaseRepo": {
          "type": "string",
          "default": "Abhigyan-Shekhar/Waggle-mcp",
          "description": "GitHub owner/repo used to download release binaries."
        },
        "waggle.binaryVersion": {
          "type": "string",
          "default": "",
          "description": "Override the GitHub release version for the bundled binary (defaults to extension version)."
        },
        "waggle.binaryAllowLatestFallback": {
          "type": "boolean",
          "default": false,
          "description": "If true, use GitHub releases/latest when the requested version tag is missing. Cache keys match the resolved release version."
        },
        "waggle.model": {
          "type": "string",
          "default": "deterministic",
          "description": "WAGGLE_MODEL value for extension-managed server processes."
        },
        "waggle.mcpConfigScope": {
          "type": "string",
          "default": "servers",
          "enum": ["servers", "mcpServers"],
          "description": "Root key to use when writing .vscode/mcp.json."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.mjs",
    "typecheck": "tsc -p ./ --noEmit",
    "test:smoke": "npm run compile && node scripts/test-platform.mjs",
    "test:regression": "npm run compile && node scripts/test-regression.mjs",
    "test:commands": "node scripts/validate-commands.js",
    "test": "npm run test:commands && npm run test:smoke && npm run test:regression",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.2",
    "@vscode/vsce": "^3.2.2"
  },
  "overrides": {
    "hono": ">=4.12.25"
  }
}
