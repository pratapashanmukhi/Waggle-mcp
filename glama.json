{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "name": "Waggle MCP",
  "description": "Persistent, graph-backed conversational memory for AI agents. Remembers decisions, reasons, and contradictions across sessions.",
  "maintainers": [
    "Abhigyan-Shekhar"
  ],
  "tags": [
    "memory",
    "knowledge-graph",
    "context",
    "local-first",
    "sqlite"
  ],
  "homepage": "https://github.com/Abhigyan-Shekhar/Waggle-mcp",
  "mcpServers": {
    "waggle": {
      "comment": "Recommended: Docker (pre-baked model, ~3 s cold start)",
      "transport": "stdio",
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-v", "waggle-data:/data",
        "-v", "waggle-cache:/cache",
        "-e", "WAGGLE_STARTUP_MODE=normal",
        "ghcr.io/abhigyan-shekhar/waggle-mcp:latest"
      ]
    },
    "waggle-fast": {
      "comment": "Fast / inspection mode — schema listing only, zero ML overhead",
      "transport": "stdio",
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-v", "waggle-data:/data",
        "-v", "waggle-cache:/cache",
        "-e", "WAGGLE_STARTUP_MODE=fast",
        "ghcr.io/abhigyan-shekhar/waggle-mcp:latest"
      ]
    }
  }
}
